          {
            "value": "{{trigger.message.From}}",
            "key": "From"
          },
          {
            "value": "{{trigger.message.To}}",
            "key": "To"
          },
          {
            "value": "{{trigger.message.Body}}",
            "key": "Body"
          },
          {
            "value": "{{trigger.message.MessageSid}}",
            "key": "MessageSid"
          }
        ],
        "url": "https://api.chmeetings.com/webhooks/thechurch/twilioresponse"
      }
    },
    {
      "name": "Welcome_Delay",
      "type": "send-and-wait-for-reply",
      "transitions": [
        {
          "next": "F-NativeForwardMessage",
          "event": "incomingMessage"
        },
        {
          "next": "F-NativeForwardMessage",
          "event": "timeout"
        },
        {
          "event": "deliveryFailure"
        }
      ],
      "properties": {
        "offset": {
          "x": -680,
          "y": 1490
        },
        "shorten_urls": true,
        "service": "{{trigger.message.InstanceSid}}",
        "channel": "{{trigger.message.ChannelSid}}",
        "from": "{{flow.channel.address}}",
        "message_type": "custom",
        "body": "Thanks! We’ve created your account, and your message is being forwarded now.  Please save this number in your contacts as theCHURCH. \nReply HELP for info. \nReply STOP to unsubscribe. Msg&Data Rates May Apply.",
        "timeout": "30"
      }
    },
    {
      "name": "Check_Mentors",
      "type": "run-function",
      "transitions": [
        {
          "next": "split_1",
          "event": "success"
        },
        {
          "event": "fail"
        }
      ],
      "properties": {
        "service_sid": "ZS648afd0ac0cdca41c79d2616955a8d06",
