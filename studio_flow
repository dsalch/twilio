      "transitions": [
        {
          "event": "noMatch"
        },
        {
          "next": "C-send_and_reply_1",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "If value equal_to unknown",
              "arguments": [
                "{{widgets.A-Check_user.parsed.status}}"
              ],
              "type": "equal_to",
              "value": "unknown"
            }
          ]
        },
        {
          "next": "F-NativeForwardMessage",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "If value equal_to success",
              "arguments": [
                "{{widgets.A-Check_user.parsed.status}}"
              ],
              "type": "equal_to",
              "value": "success"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.A-Check_user.parsed.status}}",
        "offset": {
          "x": -700,
          "y": 580
        }
      }
    },
    {
      "name": "C-send_and_reply_1",
      "type": "send-and-wait-for-reply",
      "transitions": [
        {
          "next": "D-Create_Notify",
          "event": "incomingMessage"
        },
        {
          "event": "timeout"
        },
        {
          "event": "deliveryFailure"
        }
      ],
      "properties": {
        "offset": {
          "x": -700,
          "y": 890
        },
        "service": "{{trigger.message.InstanceSid}}",
        "channel": "{{trigger.message.ChannelSid}}",
        "from": "{{flow.channel.address}}",
