          {
            "value": "{{trigger.message.From}}",
            "key": "From"
          },
          {
            "value": "{{trigger.message.Body}}",
            "key": "Body"
          },
          {
            "value": "{{widgets.C-send_and_reply_1.inbound.Body}}",
            "key": "SenderName"
          }
        ],
        "url": "https://chmeetings-sms-1218.twil.io/process_sms"
      }
    },
    {
      "name": "F-NativeForwardMessage",
      "type": "make-http-request",
      "transitions": [
        {
          "next": "Check_Mentors",
          "event": "success"
        },
        {
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": -300,
          "y": 1740
        },
        "method": "POST",
        "content_type": "application/x-www-form-urlencoded;charset=utf-8",
