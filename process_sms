const axios = require('axios');

exports.handler = async function(context, event, callback) {
  const client = context.getTwilioClient();
  // --- CONFIGURATION ---
  const API_KEY = "2C87099FF2342A5C391EDFAFDEC8E4D311FC24104D27E76B78EBA03D70DB8B5B673A375F631F03A1"; 
  // ---------------------

  const senderPhone = event.From;
  const senderNameInput = event.SenderName || ""; 

  const normalizePhone = (p) => {
      if (!p) return "";
      let clean = String(p).replace(/\D/g, ''); 
      if (clean.length === 11 && clean.startsWith('1')) {
          return clean.substring(1);
      }
      return clean;
  };

  // Format as (555) 123-4567
  const formatPhoneNice = (p) => {
      const clean = normalizePhone(p);
      if (clean.length === 10) {
          return `(${clean.substring(0,3)}) ${clean.substring(3,6)}-${clean.substring(6)}`;
      }
      return p;
  };

  try {
    console.log(`[STEP 1] START. Sender: ${senderPhone}`);
    // 1. SEARCH
    const listResponse = await axios.get("https://api.chmeetings.com/api/v1/people?page_size=1000", {
      headers: { 'ApiKey': API_KEY, 'Content-Type': 'application/json' }
    });
    let allPeople = listResponse.data;
    if (!Array.isArray(allPeople)) {
        if (allPeople.data) allPeople = allPeople.data;
        else if (allPeople.results) allPeople = allPeople.results;
        else if (Array.isArray(allPeople.people)) allPeople = allPeople.people;
        else if (Array.isArray(allPeople.items)) allPeople = allPeople.items;
    }

    console.log(`[STEP 2] Directory fetched. Found ${allPeople.length} records.`);

    const target = normalizePhone(senderPhone);
    // 2. FIND SENDER
    let summaryProfile = allPeople.find(p => {
        const dbMobile = normalizePhone(p.mobile || p.Mobile || "");
        const dbHome = normalizePhone(p.home_phone || p.HomePhone || "");
        return dbMobile === target || dbHome === target;
    });

    // 3. HANDLE UNKNOWN USER
    if (!summaryProfile && senderNameInput !== "") {
       console.log("[STEP 3] Creating NEW user...");
       const parts = senderNameInput.trim().split(" ");
       const fName = parts[0];
       const lName = parts.length > 1 ? parts.slice(1).join(" ") : "Visitor";
       const prettyPhone = formatPhoneNice(senderPhone);

       const createRes = await axios.post("https://api.chmeetings.com/api/v1/people", {
           first_name: fName,
           last_name: lName,
           mobile: prettyPhone, 
           do_not_text: false, 
           do_not_email: false
       }, { headers: { 'ApiKey': API_KEY } });
       
       console.log("[STEP 3a] User created. Triggering 'Double-Tap' update...");
       // B. WAIT (Short pause to let DB Write happen)
       await new Promise(r => setTimeout(r, 2000));
       // C. RE-UPDATE (The "Wake Up" Call)
       let newId = null;
       if (createRes.data && createRes.data.person_id) newId = createRes.data.person_id;
       else if (createRes.data && createRes.data.data && createRes.data.data.person_id) newId = createRes.data.data.person_id;
       
       if (newId) {
           console.log(`[STEP 3b] Updating ID ${newId} to force indexing...`);
           await axios.put(`https://api.chmeetings.com/api/v1/people/${newId}`, {
               mobile: prettyPhone,
               do_not_text: false
           }, { headers: { 'ApiKey': API_KEY } });
       }
       
       // RETURN NAME FOR STUDIO
       return callback(null, { status: "success", action: "created", name: `${fName} ${lName}` });

    } else if (!summaryProfile) {
        console.log("[RESULT] Sender unknown.");
        return callback(null, { status: "unknown" });
    } else {
        console.log(`[STEP 4] User found: ID ${summaryProfile.person_id || summaryProfile.id}`);
        // RETURN NAME FOR STUDIO
        const foundName = `${summaryProfile.first_name} ${summaryProfile.last_name}`;
        return callback(null, { status: "success", action: "found", name: foundName });
    }

  } catch (error) {
    console.error("[CRITICAL ERROR]", error.message);
    if (error.response && error.response.data) {
        console.error("API RESPONSE:", JSON.stringify(error.response.data));
    }
    return callback(null, { status: "error", error: error.message });
  }
};
